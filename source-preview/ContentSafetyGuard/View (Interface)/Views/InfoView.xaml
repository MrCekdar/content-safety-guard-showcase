<UserControl x:Class="ContentSafetyGuard.View__Interface_.Views.InfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ContentSafetyGuard.View__Interface_"
             mc:Ignorable="d" 
             d:DesignHeight="720"
             d:DesignWidth="900">

    <Grid Background="{StaticResource SidebarBackground}">

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled" Style="{StaticResource ViewScrollViewerStyle}">

            <Border>

                <StackPanel>

                    <Grid Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Info"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"/>

                            <TextBlock Text="Informationen über Content Safety Guard."
                                       FontSize="14"
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Content Safety Guard v1.4.2"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>

                            <TextBlock Text="Diese Seite wird angezeigt, wenn du links auf ℹ️ klickst."
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,8,0,0"/>

                            <Border Background="#1A2538"
                                    CornerRadius="10"
                                    Padding="12,8"
                                    HorizontalAlignment="Left"
                                    Margin="0,14,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Release:"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}"
                                               VerticalAlignment="Center"/>

                                    <TextBlock x:Name="ReleaseStatusText"
                                               Text="Free release"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBlue}"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <Expander Foreground="{StaticResource TextPrimary}">
                            <Expander.Header>
                                <TextBlock Text="Click For more information"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}"/>
                            </Expander.Header>

                            <StackPanel Margin="0,12,0,0">
                                <TextBlock Text="Model licenses"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}"/>

                                <TextBlock Text="NSFW model: Falconsai/nsfw_image_detection - Apache-2.0"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondary}"
                                           Margin="0,8,0,0"/>

                                <TextBlock Text="When distributing the app, keep model attribution and Apache-2.0 license notices with your release files."
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondary}"
                                           Margin="0,10,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Expander>
                    </Border>

                </StackPanel>

            </Border>

        </ScrollViewer>

    </Grid>
</UserControl>
