<UserControl x:Class="ContentSafetyGuard.View__Interface_.SettingViewFolder.Cards.PrivacyLocalAiCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ContentSafetyGuard.View__Interface_.SettingViewFolder.Cards"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="39"/>
            <Setter Property="Width" Value="167"/>
            <Setter Property="Padding" Value="15,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#1D1A25"/>
            <Setter Property="Foreground" Value="#D76060"/>
            <Setter Property="BorderBrush" Value="#3B2228"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="10"
                        SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2A1C25"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#D76060"/>
                                <Setter Property="Foreground" Value="#FF7A7A"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3B2228"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FF7A7A"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <Border Style="{DynamicResource CardStyle}">
            <StackPanel>
                <!-- Header -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <materialDesign:PackIcon Kind="LockOutline" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" Width="18" Height="18"/>
                    <TextBlock Text="PRIVACY &amp; LOCAL AI" FontSize="13" Foreground="{DynamicResource TextSecondary}" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Info Boxes Grid -->
                <Grid Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Local Processing Box -->
                    <Border Grid.Column="0" Background="#162234" CornerRadius="6" Padding="15">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="Cpu64Bit" Foreground="#6A90CA" Width="20" Height="20" Margin="0,0,0,10"/>
                            <TextBlock Text="Screen frames are processed locally." FontSize="13" Foreground="#6A90CA" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- No Saving Box -->
                    <Border Grid.Column="2" Background="#0C2621" BorderBrush="#144336" BorderThickness="1" CornerRadius="6" Padding="15">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="Harddisk" Foreground="#29B47A" Width="20" Height="20" Margin="0,0,0,10"/>
                            <TextBlock Text="No screenshots are saved or uploaded." FontSize="13" Foreground="#29B47A" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- AI Model Status -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                    <Border Background="#12332A" CornerRadius="16" Width="32" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="ShieldCheckOutline" Foreground="#29B47A" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="AI Model Status" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <Ellipse Width="6" Height="6" Fill="#29B47A" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Loaded and operational" FontSize="12" Foreground="#29B47A"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Clear Data Button -->
                <Button Style="{StaticResource DangerButtonStyle}" Content="Clear temporary data" 
                        HorizontalAlignment="Left" Foreground="#D76060" BorderBrush="#3B2228" 
                        BorderThickness="1" Background="#1D1A25" materialDesign:ButtonAssist.CornerRadius="10"
                        Padding="15,5" Height="39" Width="167"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
