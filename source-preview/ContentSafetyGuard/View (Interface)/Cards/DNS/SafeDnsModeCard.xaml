<UserControl x:Class="ContentSafetyGuard.View__Interface_.Cards.DNS.SafeDnsModeCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="280"
             d:DesignWidth="900">

    <UserControl.Resources>

        <Style x:Key="DnsSecondaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="135"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#1A2538"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="#2F405B"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#22314A"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#3B5275"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#172235"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#3078E6"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="DnsPrimaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="130"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{DynamicResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3B8BFF"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#3B8BFF"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2464C8"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#2464C8"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#2C3A4E"/>
                                <Setter Property="BorderBrush" Value="#2C3A4E"/>
                                <Setter Property="Foreground" Value="#6B7A90"/>
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Border Style="{DynamicResource CardStyle}">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                <materialDesign:PackIcon Kind="Server" Foreground="{DynamicResource TextSecondary}" Width="18" Height="18" VerticalAlignment="Center"/>
                <TextBlock Text="SAFE DNS MODE" FontSize="13" Foreground="{DynamicResource TextSecondary}" FontWeight="SemiBold" Margin="10,0,8,0" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Text="This feature changes your Windows DNS settings to use the selected third-party provider. DNS queries may be processed by that provider. Content Safety Guard is not affiliated with or endorsed by these providers."
                       Foreground="{DynamicResource TextSecondary}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="0,0,0,18"/>

            <Border x:Name="LockedMessage"
                    Background="#1A2538"
                    BorderBrush="#26364F"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14"
                    Margin="0,0,0,18"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="LockOutline" Foreground="#F5A400" Width="18" Height="18" Margin="0,0,10,0"/>
                    <TextBlock Text="Safe DNS Mode is currently disabled."
                               Foreground="{DynamicResource TextPrimary}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="330"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="DNS Provider" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="Choose a preset or provide custom DNS servers" FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,3,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <ComboBox Style="{StaticResource DarkComboBoxStyle}" x:Name="ProviderComboBox"
                              Height="40"
                              Background="#1A2538"
                              Foreground="{DynamicResource TextPrimary}"
                              BorderThickness="0"
                              Padding="10,6"
                              DisplayMemberPath="Name"/>

                    <TextBox x:Name="CustomDnsTextBox"
                             Margin="0,10,0,0"
                             Height="38"
                             Background="#1A2538"
                             Foreground="{DynamicResource TextPrimary}"
                             BorderThickness="0"
                             Padding="10,0"
                             VerticalContentAlignment="Center"
                             Visibility="Collapsed"
                             materialDesign:HintAssist.Hint="Example: 1.1.1.3, 1.0.0.3"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                        <Button Style="{StaticResource DnsSecondaryButtonStyle}"
                                Margin="0,0,10,0"
                                Click="ResetDns_Click"> 
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="Restore"
                                 Width="15"
                                 Height="15"
                                 Margin="0,0,7,0"
                                 VerticalAlignment="Center"/>
                                <TextBlock Text="Disable Safe DNS" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource DnsPrimaryButtonStyle}"
                            Click="ApplyDns_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="Check"
                                 Width="15"
                                 Height="15"
                                 Margin="0,0,7,0"
                                 VerticalAlignment="Center"/>
                                <TextBlock Text="Apply DNS"
                                VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
