<UserControl x:Class="ContentSafetyGuard.View__Interface_.SettingViewFolder.Cards.ScreenTime.ScreenTimeCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="680"
             d:DesignWidth="900">

    <Border Style="{StaticResource CardStyle}">
        <StackPanel>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ChartDonut"
                                             Width="18"
                                             Height="18"
                                             Foreground="{StaticResource TextSecondary}"
                                             VerticalAlignment="Center"/>
                    <TextBlock Text="SCREEN TIME"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondary}"
                               FontWeight="SemiBold"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="Local only"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBlue}"
                           VerticalAlignment="Center"/>
            </Grid>

            <Border Background="#0F1724"
                    BorderBrush="#1C273A"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="18"
                    Margin="0,0,0,18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="230"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    VerticalAlignment="Top"
                                    Margin="0,0,24,0">
                            <TextBlock Text="Heute"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondary}"/>
                            <TextBlock x:Name="TotalScreenTimeText"
                                       Text="0 min"
                                       FontSize="40"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"
                                       Margin="0,6,0,8"/>
                            <TextBlock Text="Aktive Fenster werden lokal gemessen."
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondary}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Diese Woche"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="{Binding WeeklyChartScaleDescription}"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondary}"
                                           HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid Height="168">
                                <Grid Height="126"
                                      Margin="0,0,34,42"
                                      VerticalAlignment="Top">
                                    <Border Height="1"
                                            Background="#1F2B3D"
                                            VerticalAlignment="Top"/>
                                    <Border Height="1"
                                            Background="#26364F"
                                            Opacity="0.65"
                                            VerticalAlignment="Center"/>
                                    <Border Height="1"
                                            Background="#1F2B3D"
                                            VerticalAlignment="Bottom"/>
                                </Grid>

                                <StackPanel Width="30"
                                            HorizontalAlignment="Right"
                                            Margin="0,0,0,42">
                                    <TextBlock Text="{Binding WeeklyChartTopLabel}"
                                               FontSize="10"
                                               Foreground="#5F6E84"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Text="{Binding WeeklyChartMidLabel}"
                                               FontSize="10"
                                               Foreground="#5F6E84"
                                               HorizontalAlignment="Right"
                                               Margin="0,45,0,0"/>
                                    <TextBlock Text="0"
                                               FontSize="10"
                                               Foreground="#5F6E84"
                                               HorizontalAlignment="Right"
                                               Margin="0,45,0,0"/>
                                </StackPanel>

                                <ItemsControl x:Name="WeeklyUsageList"
                                              Margin="0,0,34,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="5,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="126"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0"
                                                      Width="24"
                                                      Height="126"
                                                      VerticalAlignment="Bottom"
                                                      HorizontalAlignment="Center">
                                                    <Border CornerRadius="8"
                                                            Background="#182337"/>
                                                    <ItemsControl ItemsSource="{Binding Segments}"
                                                                  VerticalAlignment="Bottom">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Vertical"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Width="24"
                                                                        Height="{Binding SegmentHeight}"
                                                                        Background="{Binding Color}"
                                                                        CornerRadius="4"
                                                                        Margin="0,0,0,1"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>

                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding DayLabel}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,8,0,0"/>
                                                <TextBlock Grid.Row="2"
                                                           Text="{Binding DisplayDuration}"
                                                           FontSize="10"
                                                           Foreground="#5F6E84"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,2,0,0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <ItemsControl x:Name="CategoryUsageList"
                                  Grid.Row="1"
                                  Margin="0,18,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Text="{Binding CategoryName}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding DisplayDuration}"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondary}"
                                               Margin="0,3,0,8"/>
                                    <Grid Height="6">
                                        <Border Background="#1A2538" CornerRadius="3"/>
                                        <Border Width="{Binding BarWidth}"
                                                Background="{Binding Color}"
                                                HorizontalAlignment="Left"
                                                CornerRadius="3"/>
                                    </Grid>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="CategoryEmptyText"
                               Grid.Row="2"
                               Text="Kategorien erscheinen nach ein paar Sekunden Nutzung."
                               FontSize="12"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="0,18,0,0"/>
                </Grid>
            </Border>

            <Border Background="#0F1724"
                    BorderBrush="#1C273A"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="18">
                <StackPanel>
                    <Grid Margin="0,0,0,14">
                        <TextBlock Text="Am meisten genutzt"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="Apps und Webseiten"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <ItemsControl x:Name="UsageList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#1C273A"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0"
                                                    Margin="0,0,18,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding CategoryName}"
                                                           FontSize="11"
                                                           Foreground="{Binding Color}"
                                                           Margin="14,0,0,0"
                                                           VerticalAlignment="Center"/>
                                            </Grid>

                                            <Grid Height="6"
                                                  Margin="0,8,0,0"
                                                  MaxWidth="340"
                                                  HorizontalAlignment="Left">
                                                <Border Width="340"
                                                        Background="#1A2538"
                                                        CornerRadius="3"/>
                                                <Border Width="{Binding BarWidth}"
                                                        Background="{Binding Color}"
                                                        HorizontalAlignment="Left"
                                                        CornerRadius="3"/>
                                            </Grid>
                                        </StackPanel>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DisplayDuration}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="EmptyStateText"
                               Text="Screen Time erscheint nach ein paar Sekunden App-Nutzung."
                               FontSize="12"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="0,4,0,0"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                Margin="0,14,0,0">
                        <Button x:Name="ShowMoreButton"
                                Style="{StaticResource FlatButton}"
                                Padding="0"
                                Click="ShowMore_Click">
                            <TextBlock Text="Mehr anzeigen"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBlue}"/>
                        </Button>

                        <Button x:Name="ShowLessButton"
                                Style="{StaticResource FlatButton}"
                                Padding="0"
                                Margin="18,0,0,0"
                                Click="ShowLess_Click"
                                Visibility="Collapsed">
                            <TextBlock Text="Weniger anzeigen"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondary}"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
