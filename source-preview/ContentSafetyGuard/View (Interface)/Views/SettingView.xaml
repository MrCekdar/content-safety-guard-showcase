<UserControl x:Class="ContentSafetyGuard.View__Interface_.SettingViewFolder.SettingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:views="clr-namespace:ContentSafetyGuard.View__Interface_"
             xmlns:DetectionFolder="clr-namespace:ContentSafetyGuard.View__Interface_.SettingViewFolder.Cards.Detection"
             xmlns:cards="clr-namespace:ContentSafetyGuard.View__Interface_.SettingViewFolder.Cards"
             xmlns:FocusModeFolder="clr-namespace:ContentSafetyGuard.View__Interface_.SettingViewFolder.Cards.FocusMode"
             xmlns:WebsiteFolder="clr-namespace:ContentSafetyGuard.View__Interface_.SettingViewFolder.Cards.WebsiteRules"
             mc:Ignorable="d" 
             d:DesignHeight="720"
             d:DesignWidth="900">

    <UserControl.Resources>
        <Style TargetType="{x:Type Border}" x:Key="SettingItemBorder">
            <Setter Property="BorderBrush" Value="#1C273A"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="0,15"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource SidebarBackground}">

        <ScrollViewer x:Name="SettingsContent"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled" Style="{StaticResource ViewScrollViewerStyle}">

            <Border>

                <StackPanel>

                    <!-- HEADER -->
                    <Grid Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Settings"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"/>

                            <TextBlock Text="Manage protection, privacy and system behavior."
                                       FontSize="14"
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- CARD 3: SYSTEM SETTINGS -->
                    <cards:SystemSettingsCard x:Name="SystemSettingsCard" />

                    <!-- CARD 4: PRIVACY / LOCAL AI -->
                    <cards:PrivacyLocalAiCard x:Name="PrivacyLocalAiCard"/>

                </StackPanel>

            </Border>

        </ScrollViewer>

     

    </Grid>
</UserControl>