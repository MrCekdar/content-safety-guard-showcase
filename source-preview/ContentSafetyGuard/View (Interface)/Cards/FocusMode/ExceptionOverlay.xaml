<UserControl x:Class="ContentSafetyGuard.View__Interface_.SettingViewFolder.Cards.FocusMode.ExceptionOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="ExceptionButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="30"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{DynamicResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
               Background="{TemplateBinding Background}"
               BorderBrush="{TemplateBinding BorderBrush}"
               CornerRadius="8"
               SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3B8BFF"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#3B8BFF"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2464C8"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#2464C8"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#2C3A4E"/>
                                <Setter Property="BorderBrush" Value="#2C3A4E"/>
                                <Setter Property="Foreground" Value="#6B7A90"/>
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid Background="#B3080D16">
        
        <Border Background="#162235"
                Width="500"
                Height="600"
                CornerRadius="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="24,10,24,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Manage Blocking"
                                   Foreground="White"
                                   FontSize="16"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Select programs that should be blocked."
                                   Foreground="#8B95A5"
                                   FontSize="13"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <Button HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#8B95A5"
                            Cursor="Hand"
                            Width="30"
                            Height="30"
                            Style="{StaticResource MaterialDesignToolButton}"
                            Click="Close_Click">
                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18"/>
                    </Button>
                </Grid>

                <Border Grid.Row="1"
                        Background="#1C2B42"
                        CornerRadius="6"
                        Padding="12,8"
                        Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="64"/>
                        </Grid.ColumnDefinitions>

                        <materialDesign:PackIcon Kind="Magnify"
                                                 Foreground="#65758C"
                                                 Width="18"
                                                 Height="18"
                                                 VerticalAlignment="Center"/>

                        <TextBox Grid.Column="1"
                                 x:Name="SearchProgramsTextBox"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="White"
                                 VerticalAlignment="Center"
                                 Margin="10,0,0,0"
                                 CaretBrush="White"
                                 materialDesign:HintAssist.Hint="Search installed programs..."
                                 materialDesign:HintAssist.Foreground="#65758C"
                                 materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                 TextChanged="SearchProgramsTextBox_TextChanged"/>
                    </Grid>
                </Border>

      
                    <ListBox x:Name="Programs"
                             Background="Transparent"
                             BorderThickness="0"
                             Grid.Row="2"
                             Padding="0,0,22,0"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Hidden">
                        
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0,8"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="36"
                                            Height="36"
                                            Background="#1C2B42"
                                            CornerRadius="8">
                                        <Grid>
                                            <Image Source="{Binding IconImage}"
                                                   Width="18"
                                                   Height="18"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IconImage}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>

                                            <materialDesign:PackIcon Kind="Application"
                                                                     Foreground="#3078E6"
                                                                     Width="18"
                                                                     Height="18"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center">
                                                <materialDesign:PackIcon.Style>
                                                    <Style TargetType="materialDesign:PackIcon">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IconImage}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </materialDesign:PackIcon.Style>
                                            </materialDesign:PackIcon>
                                        </Grid>
                                    </Border>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ProgramName}"
                                               Foreground="White"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               Margin="14,0,0,0"/>

                                <ToggleButton Grid.Column="2"
                                                  IsChecked="{Binding IsBlocked, Mode=TwoWay}"
                                                  IsEnabled="{Binding HasExecutableTarget}"
                                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                                  Background="#2A3548"
                                                  Cursor="Hand"
                                                  Margin="0,0,0,0"
                                                  VerticalAlignment="Center">
                                    
                                        
                                </ToggleButton>

                            </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                <Grid Grid.Row="3" Margin="0,010,0,0">
                    <Button Content="Browse..."
                            Background="#1C2B42"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Height="41"
                            HorizontalAlignment="Left"
                            Padding="24,0"
                            materialDesign:ButtonAssist.CornerRadius="6"
                            BorderThickness="0"
                            Style="{StaticResource ExceptionButton}"
                            Cursor="Hand"
                            Click="Browse_Click"/>

                    <Button Content="Done"
                            Background="#3078E6"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Style="{StaticResource ExceptionButton}"
                            Height="40"
                            HorizontalAlignment="Right"
                            Padding="24,0"
                            materialDesign:ButtonAssist.CornerRadius="6"
                            BorderThickness="0"
                            Margin="0,0,15,0"
                            Cursor="Hand"
                            Click="Done_Click"/>
                </Grid>
            </Grid>
        </Border>
        
        
    </Grid>
</UserControl>
